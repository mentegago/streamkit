    "version": "0.2.0",
    "configurations": [
        {
            "name": "streamkit (Twitch)",
            "request": "launch",
            "type": "dart",
            "preLaunchTask": "set-icon-twitch"
        },
        {
            "name": "streamkit (Twitch, profile)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "preLaunchTask": "set-icon-twitch"
        },
        {
            "name": "streamkit (Twitch, release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "preLaunchTask": "set-icon-twitch"
        },
        {
            "name": "streamkit (YouTube)",
            "request": "launch",
            "type": "dart",
            "toolArgs": ["--dart-define=FLAVOR=youtube"],
            "preLaunchTask": "set-icon-youtube"
        },
        {
            "name": "streamkit (YouTube, profile)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "toolArgs": ["--dart-define=FLAVOR=youtube"],
            "preLaunchTask": "set-icon-youtube"
        },
        {
            "name": "streamkit (YouTube, release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": ["--dart-define=FLAVOR=youtube"],
            "preLaunchTask": "set-icon-youtube"
        }
    ]
}